# App
NEXT_PUBLIC_APP_URL=https://thegrainline.com
NODE_ENV=development
# Optional Search Console ownership meta tag value
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=google-site-verification-token

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech:5432/DATABASE?sslmode=verify-full
DIRECT_URL=postgresql://USER:PASSWORD@DIRECT_HOST.REGION.aws.neon.tech:5432/DATABASE?sslmode=verify-full
# Retained non-customer SavedSearch RLS canary used by /api/cron/ops-health.
# Configure both values before rollout. Missing, partial, malformed, or mismatched
# values make ops-health unhealthy. Both ids must share one 12-32 character
# lowercase hexadecimal nonce, and the exact row must remain in the database.
SAVED_SEARCH_RLS_CANARY_USER_ID=rls-saved-search-canary-0123456789abcdef-user
SAVED_SEARCH_RLS_CANARY_SEARCH_ID=rls-saved-search-canary-0123456789abcdef-search

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Separate Stripe Events v2 / thin-event destination for Connect account events
STRIPE_V2_WEBHOOK_SECRET=whsec_xxx

# Admin PIN
ADMIN_PIN=change-me
# Preferred for production staff accounts: JSON object mapping Clerk user IDs to
# SHA-256 hex digests of each user's PIN. Generate a digest with:
# node -e "const crypto=require('crypto'); console.log(crypto.createHash('sha256').update(process.argv[1]).digest('hex'))" 123456
# When this is set, staff users missing from the map cannot fall back to ADMIN_PIN.
# ADMIN_PIN_SHA256_BY_CLERK_ID={"user_xxx":"64-char-sha256-hex"}
ADMIN_PIN_COOKIE_SECRET=64-plus-random-characters-for-signed-admin-pin-cookies
# Optional local-only stable dev cookie secret; production must use ADMIN_PIN_COOKIE_SECRET
# ADMIN_PIN_COOKIE_SECRET_DEV=local-dev-only-secret

# Cloudflare R2
CLOUDFLARE_R2_ACCOUNT_ID=account-id
CLOUDFLARE_R2_ACCESS_KEY_ID=access-key-id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=secret-access-key
CLOUDFLARE_R2_BUCKET_NAME=grainline-uploads
CLOUDFLARE_R2_PUBLIC_URL=https://cdn.example.com
UPLOAD_VERIFICATION_SECRET=64-plus-random-characters-for-upload-verification-tokens

# Shippo
SHIPPO_API_KEY=shippo_test_xxx
SHIPPING_RATE_SECRET=64-char-hex-secret-used-to-sign-shipping-rate-tokens

# Resend
RESEND_API_KEY=re_xxx
EMAIL_FROM=Grainline <hello@send.thegrainline.com>
RESEND_WEBHOOK_SECRET=whsec_xxx
UNSUBSCRIBE_SECRET=64-plus-random-characters-for-one-click-email-unsubscribe-links
# Optional quota override; defaults to 3000/day when unset
# EMAIL_OUTBOX_DAILY_LIMIT=3000

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://example.upstash.io
UPSTASH_REDIS_REST_TOKEN=upstash-token

# OpenAI
OPENAI_API_KEY=sk-proj_xxx

# Cron
CRON_SECRET=random-cron-secret
# Optional previous value during cron secret rotation
# CRON_SECRET_PREVIOUS=old-random-cron-secret

# Health checks
# Required only for verbose dependency details from /api/health
HEALTH_CHECK_TOKEN=random-health-check-token

# Sentry
NEXT_PUBLIC_SENTRY_DSN=https://example.ingest.sentry.io/project
SENTRY_DSN=https://example.ingest.sentry.io/project
SENTRY_AUTH_TOKEN=sntrys_xxx

# Optional local-only helpers
# Leave VERCEL_ENV unset for local-only dev fixtures; Vercel runtimes must stay disabled.
# Only enable fixture/backfill flags against a disposable local DB, never shared demo/QA data.
# ENABLE_DEV_MAKE_ORDER=true
# ALLOW_DEV_ADMIN_PIN_BYPASS=true
# ALLOW_METRO_BACKFILL=true
