// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

// Connection setup:
// - DATABASE_URL (runtime): should use Neon's pooled endpoint (-pooler
//   suffix in hostname) for connection reuse across serverless functions.
//   Set in Vercel env vars. PgBouncer multiplexes connections — prevents
//   connection exhaustion under concurrent load.
// - DIRECT_URL (migrations only): uses direct endpoint (no pooler).
//   Required for prisma migrate — PgBouncer doesn't support DDL.
// Both are configured in prisma.config.ts (Prisma 7 pattern).
// See: https://neon.tech/docs/connect/connection-pooling
datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  EMPLOYEE
  ADMIN
}

enum ListingType {
  MADE_TO_ORDER
  IN_STOCK
}

enum Category {
  FURNITURE
  KITCHEN
  DECOR
  TOOLS
  TOYS
  JEWELRY
  ART
  OUTDOOR
  STORAGE
  OTHER
}

enum ListingStatus {
  DRAFT
  ACTIVE
  SOLD
  SOLD_OUT
  HIDDEN
  PENDING_REVIEW
  REJECTED
}

model User {
  id        String    @id @default(cuid())
  clerkId   String    @unique @db.VarChar(255)
  email     String    @unique @db.VarChar(254)
  name      String?   @db.VarChar(100)
  imageUrl  String?   @db.VarChar(2048)
  role      Role      @default(USER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Compliance / lifecycle
  termsAcceptedAt    DateTime?
  termsVersion       String?   @db.VarChar(50)
  ageAttestedAt      DateTime?
  welcomeEmailSentAt DateTime?

  // Buyer shipping address
  shippingName       String?   @db.VarChar(100)
  shippingLine1      String?   @db.VarChar(200)
  shippingLine2      String?   @db.VarChar(200)
  shippingCity       String?   @db.VarChar(100)
  shippingState      String?   @db.VarChar(50)
  shippingPostalCode String?   @db.VarChar(20)
  shippingPhone      String?   @db.VarChar(30)

  conversationsAsA Conversation[] @relation("ConvoA")
  conversationsAsB Conversation[] @relation("ConvoB")
  messagesSent     Message[]      @relation("MessagesFromUser")
  messagesReceived Message[]      @relation("MessagesToUser")

  sellerProfile SellerProfile?
  favorites     Favorite[]
  reviews       Review[]

  // Orders & review votes
  orders      Order[]      @relation("OrdersByBuyer")
  reviewVotes ReviewVote[]

  // Cart
  cart Cart?

  // Cases
  casesAsBuyer  Case[]        @relation("CasesByBuyer")
  casesAsSeller Case[]        @relation("CasesBySeller")
  casesResolved Case[]        @relation("CasesResolvedBy")
  caseMessages  CaseMessage[] @relation("CaseMessages")

  savedSearches      SavedSearch[]
  stockNotifications StockNotification[]

  reservedListings    Listing[]           @relation("ReservedListings")
  verificationReviews MakerVerification[] @relation("VerificationReviews")
  blogPosts           BlogPost[]          @relation("BlogPostsAuthored")
  blogComments        BlogComment[]       @relation("BlogCommentsAuthored")
  notifications       Notification[]

  follows            Follow[]            @relation("UserFollows")
  savedBlogPosts     SavedBlogPost[]
  commissionRequests CommissionRequest[] @relation("CommissionRequests")

  notificationPreferences Json @default("{}")

  banned       Boolean         @default(false)
  bannedAt     DateTime?
  banReason    String?         @db.VarChar(500)
  bannedBy     String?         @db.VarChar(255)
  adminActions AdminAuditLog[] @relation("AdminActions")

  blocks          Block[]      @relation("UserBlocks")
  blockedBy       Block[]      @relation("UserBlockedBy")
  reports         UserReport[] @relation("UserReports")
  reportedBy      UserReport[] @relation("UserReportedBy")
  reportsResolved UserReport[] @relation("UserReportsResolved")

  @@index([deletedAt])
}

model SellerProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName    String   @db.VarChar(100)
  bio            String?
  city           String?  @db.VarChar(100)
  state          String?  @db.VarChar(50)
  lat            Float?
  lng            Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  radiusMeters   Int?
  publicMapOptIn Boolean  @default(false)

  // Stripe Connect
  stripeAccountId                   String? @unique @db.VarChar(255)
  chargesEnabled                    Boolean @default(false)
  manualStripeReconciliationNeeded  Boolean @default(false)
  manualStripeReconciliationNote    String? @db.VarChar(1000)

  // Flat-rate shipping (legacy/simple fallback)
  shippingFlatRateCents Int?
  freeShippingOverCents Int?
  allowLocalPickup      Boolean @default(false)

  // 🆕 Ship-from address (used for live-rate quoting/labels)
  shipFromName    String? @db.VarChar(100)
  shipFromLine1   String? @db.VarChar(200)
  shipFromLine2   String? @db.VarChar(200)
  shipFromCity    String? @db.VarChar(100)
  shipFromState   String? @db.VarChar(50)
  shipFromPostal  String? @db.VarChar(20)
  shipFromCountry String? @default("US") @db.VarChar(2)

  // 🆕 Default package (used when listings don’t specify packaged dims)
  defaultPkgWeightGrams Int?
  defaultPkgLengthCm    Float?
  defaultPkgWidthCm     Float?
  defaultPkgHeightCm    Float?

  // Use live carrier rates (Shippo) instead of flat rate by default
  useCalculatedShipping Boolean @default(false)

  // Preferred carriers for shipping quotes (empty = show all)
  preferredCarriers String[] @default([])

  // Rich profile / personalization
  tagline                   String?    @db.VarChar(140)
  bannerImageUrl            String?    @db.VarChar(2048)
  avatarImageUrl            String?    @db.VarChar(2048)
  workshopImageUrl          String?    @db.VarChar(2048)
  storyTitle                String?    @db.VarChar(200)
  storyBody                 String?
  instagramUrl              String?    @db.VarChar(2048)
  facebookUrl               String?    @db.VarChar(2048)
  pinterestUrl              String?    @db.VarChar(2048)
  tiktokUrl                 String?    @db.VarChar(2048)
  websiteUrl                String?    @db.VarChar(2048)
  yearsInBusiness           Int?
  acceptsCustomOrders       Boolean    @default(false)
  acceptingNewOrders        Boolean    @default(true)
  customOrderTurnaroundDays Int?
  offersGiftWrapping        Boolean    @default(false)
  giftWrappingPriceCents    Int?
  returnPolicy              String?
  customOrderPolicy         String?
  shippingPolicy            String?
  featuredListingIds        String[]   @default([])
  galleryImageUrls          String[]   @default([])
  isVerifiedMaker           Boolean    @default(false)
  verifiedAt                DateTime?
  guildLevel                GuildLevel @default(NONE)
  guildMemberApprovedAt     DateTime?
  guildMasterApprovedAt     DateTime?
  guildMasterAppliedAt      DateTime?
  guildMasterReviewNotes    String?    @db.VarChar(2000)

  // Guild Phase 3 — revoke tracking
  consecutiveMetricFailures   Int       @default(0)
  lastMetricCheckAt           DateTime?
  metricWarningSentAt         DateTime?
  listingsBelowThresholdSince DateTime?

  // Seller onboarding wizard
  onboardingStep     Int     @default(0)
  onboardingComplete Boolean @default(false)

  // Vacation mode
  vacationMode       Boolean   @default(false)
  vacationReturnDate DateTime?
  vacationMessage    String?   @db.VarChar(500)

  // Analytics
  profileViews Int @default(0)

  // Admin-featured spotlight (set by admin for 7 days to pin to Meet a Maker)
  featuredUntil DateTime?

  // Metro geography (set automatically from lat/lng)
  metroId     String?
  metro       Metro?  @relation("SellerMetro", fields: [metroId], references: [id])
  cityMetroId String?
  cityMetro   Metro?  @relation("SellerCityMetro", fields: [cityMetroId], references: [id])

  listings            Listing[]
  faqs                SellerFaq[]
  makerVerification   MakerVerification?
  blogPosts           BlogPost[]
  sellerMetrics       SellerMetrics?
  ratingSummary       SellerRatingSummary?
  viewDailies         ListingViewDaily[]
  followers           Follow[]
  broadcasts          SellerBroadcast[]
  commissionInterests CommissionInterest[]
  payoutEvents        SellerPayoutEvent[]

  @@index([featuredUntil])
  @@index([guildLevel, chargesEnabled, vacationMode])
}

model SellerFaq {
  id              String        @id @default(cuid())
  sellerProfileId String
  sellerProfile   SellerProfile @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)
  question        String        @db.VarChar(200)
  answer          String        @db.VarChar(2000)
  sortOrder       Int           @default(0)
  createdAt       DateTime      @default(now())

  @@index([sellerProfileId, sortOrder])
}

model Listing {
  id          String        @id @default(cuid())
  sellerId    String
  seller      SellerProfile @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  title       String        @db.VarChar(150)
  description String
  priceCents  Int
  currency    String        @default("usd") @db.VarChar(3)
  status      ListingStatus @default(ACTIVE)
  videoUrl    String?       @db.VarChar(2048)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Processing time
  processingTimeMinDays Int?
  processingTimeMaxDays Int?

  // Listing type & inventory
  listingType   ListingType @default(MADE_TO_ORDER)
  stockQuantity Int?

  // Category & analytics
  category   Category?
  viewCount  Int       @default(0)
  clickCount Int       @default(0)

  // SEO/browse tags
  tags String[] @default([])

  // Ships-within days (IN_STOCK only; used instead of processingTimeMaxDays for delivery estimate)
  shipsWithinDays Int?

  photos    Photo[]
  favorites Favorite[]
  reviews   Review[]

  // purchases
  orderItems OrderItem[]

  // Cart back-rel
  cartItems CartItem[]

  // 🆕 Packaged dimensions/weight (final, ready-to-ship per unit)
  packagedWeightGrams Int?
  packagedLengthCm    Float?
  packagedWidthCm     Float?
  packagedHeightCm    Float?

  contextConversations Conversation[]      @relation("ConversationContextListing")
  stockNotifications   StockNotification[]
  viewDailies          ListingViewDaily[]

  // Custom order fields
  isPrivate                 Boolean @default(false)
  reservedForUserId         String?
  reservedForUser           User?   @relation("ReservedListings", fields: [reservedForUserId], references: [id])
  customOrderConversationId String?

  // AI review fields
  aiReviewFlags   String[]  @default([])
  aiReviewScore   Float?
  reviewedByAdmin Boolean   @default(false)
  reviewedAt      DateTime?
  rejectionReason String?   @db.VarChar(1000)

  // SEO & product details
  metaDescription String?   @db.VarChar(320)
  materials       String[] @default([])
  productLengthIn Float?
  productWidthIn  Float?
  productHeightIn Float?

  // Variants (up to 3 groups × 10 options each)
  variantGroups ListingVariantGroup[]

  // Quality score (recalculated daily by cron)
  qualityScore Float @default(0)

  // Metro geography (set automatically on create/update from seller location)
  metroId     String?
  metro       Metro?  @relation("ListingMetro", fields: [metroId], references: [id])
  cityMetroId String?
  cityMetro   Metro?  @relation("ListingCityMetro", fields: [cityMetroId], references: [id])

  @@index([sellerId, status])
  @@index([status, createdAt])
  @@index([title])
  @@index([category, status])
  @@index([viewCount])
  @@index([clickCount])
  @@index([status, isPrivate, qualityScore])
  @@index([priceCents])
  @@index([qualityScore])
  @@index([sellerId, updatedAt])
}

model Photo {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url       String   @db.VarChar(2048)
  altText   String?  @db.VarChar(200)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([listingId, sortOrder])
}

model Favorite {
  userId    String
  listingId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, listingId])
}

model Review {
  id            String    @id @default(cuid())
  listingId     String
  listing       Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  reviewerId    String
  reviewer      User      @relation(fields: [reviewerId], references: [id], onDelete: Cascade)
  ratingX2      Int
  comment       String?   @db.VarChar(2000)
  verified      Boolean   @default(false)
  helpfulCount  Int       @default(0)
  sellerReply   String?   @db.VarChar(2000)
  sellerReplyAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  photos ReviewPhoto[]
  votes  ReviewVote[]

  @@unique([listingId, reviewerId])
  @@index([listingId])
  @@index([listingId, createdAt])
  @@index([reviewerId])
}

model Conversation {
  id        String    @id @default(cuid())
  userAId   String
  userBId   String
  userA     User      @relation("ConvoA", fields: [userAId], references: [id], onDelete: Cascade)
  userB     User      @relation("ConvoB", fields: [userBId], references: [id], onDelete: Cascade)
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  contextListingId String?
  contextListing   Listing?  @relation("ConversationContextListing", fields: [contextListingId], references: [id])
  archivedAAt      DateTime?
  archivedBAt      DateTime?
  firstResponseAt  DateTime?

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
  @@index([createdAt])
}

model Message {
  id              String       @id @default(cuid())
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId        String
  sender          User         @relation("MessagesFromUser", fields: [senderId], references: [id], onDelete: Cascade)
  recipientId     String
  recipient       User         @relation("MessagesToUser", fields: [recipientId], references: [id], onDelete: Cascade)
  body            String       @db.VarChar(5000)
  kind            String?      @db.VarChar(50)
  isSystemMessage Boolean      @default(false)
  readAt          DateTime?
  createdAt       DateTime     @default(now())

  @@index([conversationId])
  @@index([conversationId, createdAt])
  @@index([recipientId, readAt])
}

model ReviewPhoto {
  id        String   @id @default(cuid())
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  url       String   @db.VarChar(2048)
  altText   String?  @db.VarChar(200)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([reviewId, sortOrder])
}

model ReviewVote {
  reviewId  String
  userId    String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  value     Int      @default(1)
  createdAt DateTime @default(now())

  @@id([reviewId, userId])
}

enum LabelStatus {
  PURCHASED
  EXPIRED
  VOIDED
}

model Order {
  id        String    @id @default(cuid())
  buyerId   String?
  buyer     User?     @relation("OrdersByBuyer", fields: [buyerId], references: [id], onDelete: SetNull)
  createdAt DateTime  @default(now())
  paidAt    DateTime?

  // Stripe idempotency
  stripeSessionId String? @unique @db.VarChar(255)

  // What Stripe actually charged / decided
  currency            String  @default("usd") @db.VarChar(3)
  itemsSubtotalCents  Int     @default(0) // items subtotal (excl. shipping & tax)
  shippingTitle       String? @db.VarChar(200)
  shippingAmountCents Int     @default(0)
  taxAmountCents      Int     @default(0)

  // Buyer snapshot
  buyerEmail       String? @db.VarChar(254)
  buyerName        String? @db.VarChar(200)
  shipToLine1      String? @db.VarChar(200)
  shipToLine2      String? @db.VarChar(200)
  shipToCity       String? @db.VarChar(100)
  shipToState      String? @db.VarChar(50)
  shipToPostalCode String? @db.VarChar(20)
  shipToCountry    String? @db.VarChar(2)

  // Stripe references
  stripePaymentIntentId  String? @unique(map: "Order_stripePaymentIntentId_idx") @db.VarChar(255)
  stripeChargeId         String? @unique(map: "Order_stripeChargeId_idx") @db.VarChar(255)
  stripeApplicationFeeId String? @db.VarChar(255)
  stripeTransferId       String? @db.VarChar(255)

  // 🆕 Fulfillment
  fulfillmentMethod FulfillmentMethod?
  fulfillmentStatus FulfillmentStatus  @default(PENDING)
  trackingCarrier   String? @db.VarChar(100)
  trackingNumber    String? @db.VarChar(100)
  pickupReadyAt     DateTime?
  pickedUpAt        DateTime?
  shippedAt         DateTime?
  deliveredAt       DateTime?
  sellerNotes       String?

  items OrderItem[]

  // Delivery estimate fields
  estimatedDeliveryDate DateTime? // processing + transit shown to buyer
  processingDeadline    DateTime? // when seller should ship by

  // Case back-relation
  case Case?

  // Snapshot of the *selected* shipping service
  shippingCarrier String? @db.VarChar(100) // e.g., "UPS"
  shippingService String? @db.VarChar(100) // e.g., "Ground"
  shippingEta     DateTime? // carrier ETA if provided

  /// What we quoted *before* Checkout (from your site/UI)
  quotedShippingAmountCents Int?

  /// Flag when Checkout address/rate doesn’t match our quote
  reviewNeeded Boolean @default(false)
  reviewNote   String?

  /// Tax reversal audit trail (webhook reverses tax portion of seller transfer)
  taxReversalId          String? @db.VarChar(255)
  taxReversalAmountCents Int?

  // 👇 NEW: what the buyer typed on your site (used for mismatch detection)

  quotedToLine1               String?   @db.VarChar(200)
  quotedToLine2               String?   @db.VarChar(200)
  quotedToCity                String?   @db.VarChar(100)
  quotedToState               String?   @db.VarChar(50)
  quotedToPostalCode          String?   @db.VarChar(20)
  quotedToCountry             String?   @db.VarChar(2)
  quotedToName                String?   @db.VarChar(200)
  quotedToPhone               String?   @db.VarChar(30)
  quotedAt                    DateTime?
  quotedUseCalculatedShipping Boolean? // what path we used

  // Seller-initiated refund
  sellerRefundId          String?   @db.VarChar(255)
  sellerRefundAmountCents Int?
  sellerRefundLockedAt    DateTime?

  // Shippo label
  shippoShipmentId    String? @db.VarChar(255)
  shippoRateObjectId  String? @db.VarChar(255)
  shippoTransactionId String? @db.VarChar(255)
  labelUrl            String? @db.VarChar(2048)
  labelCarrier        String? @db.VarChar(100)
  labelTrackingNumber String? @db.VarChar(100)
  labelPurchasedAt    DateTime?
  labelCostCents      Int?
  labelStatus         LabelStatus?

  // Gift options
  giftNote               String?   @db.VarChar(500)
  giftWrapping           Boolean   @default(false)
  giftWrappingPriceCents Int?
  buyerDataPurgedAt      DateTime?

  shippingRateQuotes OrderShippingRateQuote[]
  paymentEvents      OrderPaymentEvent[]

  @@index([buyerId])
  @@index([buyerId, createdAt])
  @@index([paidAt])
  @@index([createdAt])
  @@index([fulfillmentStatus])
  @@index([fulfillmentStatus, createdAt])
  @@index([sellerRefundId, sellerRefundLockedAt])
  @@index([buyerDataPurgedAt, fulfillmentStatus, deliveredAt, pickedUpAt], map: "Order_buyer_pii_prune_idx")
}

model OrderShippingRateQuote {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  shipmentId String   @db.VarChar(255)
  rates      Json
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([orderId, expiresAt])
  @@index([expiresAt])
}

model OrderPaymentEvent {
  id               String   @id @default(cuid())
  orderId          String
  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  stripeEventId    String   @unique @db.VarChar(255)
  stripeObjectId   String?  @db.VarChar(255)
  stripeObjectType String?  @db.VarChar(100)
  eventType        String   @db.VarChar(100)
  amountCents      Int?
  currency         String   @default("usd") @db.VarChar(3)
  status           String?  @db.VarChar(100)
  reason           String?  @db.VarChar(255)
  description      String?
  metadata         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([orderId, createdAt])
  @@index([eventType, createdAt])
  @@index([stripeObjectId])
}

model SellerPayoutEvent {
  id              String        @id @default(cuid())
  sellerProfileId String
  sellerProfile   SellerProfile @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)
  stripePayoutId  String        @unique @db.VarChar(255)
  status          String        @db.VarChar(100)
  amountCents     Int?
  currency        String        @default("usd") @db.VarChar(3)
  failureCode     String?       @db.VarChar(100)
  failureMessage  String?       @db.VarChar(1000)
  stripeEventId   String?       @db.VarChar(255)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([sellerProfileId, createdAt])
  @@index([status, createdAt])
}

model OrderItem {
  id               String   @id @default(cuid())
  orderId          String
  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  listingId        String
  listing          Listing  @relation(fields: [listingId], references: [id], onDelete: Restrict)
  quantity         Int      @default(1)
  priceCents       Int
  listingSnapshot  Json?
  selectedVariants Json? // [{ groupName, optionLabel, priceAdjustCents }]
  createdAt        DateTime @default(now())

  @@index([orderId])
  @@index([listingId])
  @@index([listingId, orderId])
}

model Cart {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items CartItem[]
}

model CartItem {
  id                       String   @id @default(cuid())
  cartId                   String
  cart                     Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  listingId                String
  listing                  Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  quantity                 Int      @default(1)
  priceCents               Int
  selectedVariantOptionIds String[] @default([])
  variantKey               String   @default("") @db.VarChar(255) // sorted option IDs, for unique constraint
  createdAt                DateTime @default(now())

  @@unique([cartId, listingId, variantKey])
  @@index([cartId])
}

model ListingVariantGroup {
  id        String                 @id @default(cuid())
  listingId String
  listing   Listing                @relation(fields: [listingId], references: [id], onDelete: Cascade)
  name      String                 @db.VarChar(100) // seller-defined: "Size", "Wood Type", "Finish", etc.
  sortOrder Int                    @default(0)
  options   ListingVariantOption[]

  @@index([listingId, sortOrder])
}

model ListingVariantOption {
  id               String              @id @default(cuid())
  groupId          String
  group            ListingVariantGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  label            String              @db.VarChar(100) // seller-defined: "Large", "Walnut", "Dark Stain", etc.
  priceAdjustCents Int                 @default(0) // +5000 = +$50, -2000 = -$20, 0 = no change
  sortOrder        Int                 @default(0)
  inStock          Boolean             @default(true)

  @@index([groupId, sortOrder])
}

model SiteConfig {
  id                    Int @id @default(1)
  fallbackShippingCents Int @default(1500)
}

enum FulfillmentMethod {
  PICKUP
  SHIPPING
}

enum FulfillmentStatus {
  PENDING // default after payment
  READY_FOR_PICKUP // seller marked ready (pickup flow)
  PICKED_UP // buyer received (pickup flow)
  SHIPPED // label purchased / handed to carrier
  DELIVERED // delivered confirmation
}

enum CaseReason {
  NOT_RECEIVED
  NOT_AS_DESCRIBED
  DAMAGED
  WRONG_ITEM
  OTHER
}

enum CaseStatus {
  OPEN
  IN_DISCUSSION
  PENDING_CLOSE
  UNDER_REVIEW
  RESOLVED
  CLOSED
}

enum CaseResolution {
  REFUND_FULL
  REFUND_PARTIAL
  DISMISSED
}

model Case {
  id                   String          @id @default(cuid())
  orderId              String          @unique
  order                Order           @relation(fields: [orderId], references: [id], onDelete: Restrict)
  buyerId              String
  buyer                User            @relation("CasesByBuyer", fields: [buyerId], references: [id], onDelete: Restrict)
  sellerId             String
  seller               User            @relation("CasesBySeller", fields: [sellerId], references: [id], onDelete: Restrict)
  reason               CaseReason
  description          String          @db.VarChar(5000)
  status               CaseStatus      @default(OPEN)
  resolution           CaseResolution?
  refundAmountCents    Int?
  stripeRefundId       String?         @db.VarChar(255)
  sellerRespondBy      DateTime
  discussionStartedAt  DateTime?
  escalateUnlocksAt    DateTime?
  buyerMarkedResolved  Boolean         @default(false)
  sellerMarkedResolved Boolean         @default(false)
  resolvedAt           DateTime?
  resolvedById         String?
  resolvedBy           User?           @relation("CasesResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)
  messages             CaseMessage[]
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@index([buyerId])
  @@index([status, createdAt])
}

model CaseMessage {
  id        String   @id @default(cuid())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation("CaseMessages", fields: [authorId], references: [id], onDelete: Restrict)
  body      String   @db.VarChar(5000)
  createdAt DateTime @default(now())

  @@index([caseId])
  @@index([caseId, createdAt])
}

model SavedSearch {
  id              String       @id @default(cuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  query           String?      @db.VarChar(200)
  category        Category?
  listingType     ListingType?
  shipsWithinDays Int?
  minRating       Int?
  lat             Float?
  lng             Float?
  radiusMiles     Int?
  sort            String?      @db.VarChar(50)
  minPrice        Int?
  maxPrice        Int?
  tags            String[]     @default([])
  notifyEmail     Boolean      @default(true)
  createdAt       DateTime     @default(now())

  @@index([userId])
}

model StockNotification {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([listingId, userId])
  @@index([listingId])
  @@index([userId])
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
  GUILD_MASTER_PENDING
  GUILD_MASTER_APPROVED
  GUILD_MASTER_REJECTED
}

enum GuildLevel {
  NONE
  GUILD_MEMBER
  GUILD_MASTER
}

model MakerVerification {
  id                       String             @id @default(cuid())
  sellerProfileId          String             @unique
  sellerProfile            SellerProfile      @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)
  craftDescription         String             @db.VarChar(1000)
  guildMasterCraftBusiness String?            @db.VarChar(1000)
  yearsExperience          Int
  portfolioUrl             String?            @db.VarChar(2048)
  status                   VerificationStatus @default(PENDING)
  reviewedById             String?
  reviewedBy               User?              @relation("VerificationReviews", fields: [reviewedById], references: [id])
  reviewNotes              String?            @db.VarChar(2000)
