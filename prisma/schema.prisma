  lastFailedAt  DateTime @default(now())
  lastEventId   String?  @db.VarChar(255)

  @@index([lastFailedAt])
}

model EmailOutbox {
  id             String    @id @default(cuid())
  recipientEmail String    @db.VarChar(254)
