  source    String?                @db.VarChar(100)
  eventId   String?                @db.VarChar(255)
  details   Json                   @default("{}")
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  @@index([reason])
  @@index([createdAt])
}

model ResendWebhookEvent {
