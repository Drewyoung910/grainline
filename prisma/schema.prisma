  ORDER_DELIVERED
  CASE_OPENED
  CASE_MESSAGE
  CASE_RESOLVED
  REFUND_ISSUED
  CUSTOM_ORDER_REQUEST
  CUSTOM_ORDER_LINK
  VERIFICATION_APPROVED
  VERIFICATION_REJECTED
  BACK_IN_STOCK
  NEW_REVIEW
  LOW_STOCK
  NEW_FAVORITE
  NEW_BLOG_COMMENT
  BLOG_COMMENT_REPLY
