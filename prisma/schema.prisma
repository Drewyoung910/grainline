model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String           @db.VarChar(200)
  body      String           @db.VarChar(1000)
  link      String?          @db.VarChar(2048)
  dedupKey  String           @default(cuid()) @db.VarChar(64)
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@unique([userId, type, dedupKey])
  @@index([userId, read])
  @@index([userId, read, createdAt])
  @@index([userId, createdAt])
  @@index([read, createdAt])
}

model ListingViewDaily {
  id              String        @id @default(cuid())
  listingId       String
  listing         Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  sellerProfileId String
  sellerProfile   SellerProfile @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)
  date            DateTime // stored as midnight UTC of that day
  views           Int           @default(0)
  clicks          Int           @default(0)

  @@unique([listingId, date])
  @@index([sellerProfileId, date])
  @@index([date])
}

model Follow {
  id              String        @id @default(cuid())
  followerId      String
  follower        User          @relation("UserFollows", fields: [followerId], references: [id], onDelete: Cascade)
  sellerProfileId String
  sellerProfile   SellerProfile @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())

  @@unique([followerId, sellerProfileId])
  @@index([sellerProfileId])
  @@index([followerId])
}

model SavedBlogPost {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  blogPostId String
  blogPost   BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, blogPostId])
  @@index([userId])
  @@index([blogPostId])
}

model SellerBroadcast {
  id              String        @id @default(cuid())
  sellerProfileId String
  sellerProfile   SellerProfile @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)
  message         String        @db.VarChar(500)
  imageUrl        String?       @db.VarChar(2048)
  sentAt          DateTime      @default(now())
  recipientCount  Int           @default(0)

  @@index([sellerProfileId])
  @@index([sentAt])
}

enum CommissionStatus {
  OPEN
  IN_PROGRESS
  FULFILLED
  CLOSED
  EXPIRED
}

model CommissionRequest {
  id                 String           @id @default(cuid())
  buyerId            String
  buyer              User             @relation("CommissionRequests", fields: [buyerId], references: [id], onDelete: Cascade)
  title              String           @db.VarChar(150)
  description        String           @db.VarChar(5000)
  category           Category?
  budgetMinCents     Int?
  budgetMaxCents     Int?
  timeline           String?          @db.VarChar(200)
  referenceImageUrls String[]         @default([])
  status             CommissionStatus @default(OPEN)
  interestedCount    Int              @default(0)
  expiresAt          DateTime?
  isNational         Boolean          @default(true)
  lat                Float?
  lng                Float?
  radiusMeters       Int?             @default(80000)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  interests CommissionInterest[]

  // Metro geography (set automatically on create from buyer location)
  metroId     String?
  metro       Metro?  @relation("CommissionMetro", fields: [metroId], references: [id])
  cityMetroId String?
  cityMetro   Metro?  @relation("CommissionCityMetro", fields: [cityMetroId], references: [id])

  @@index([buyerId])
  @@index([status, createdAt])
  @@index([category])
}

model CommissionInterest {
  id                  String            @id @default(cuid())
  commissionRequestId String
  commissionRequest   CommissionRequest @relation(fields: [commissionRequestId], references: [id], onDelete: Cascade)
  sellerProfileId     String
  sellerProfile       SellerProfile     @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)
  conversationId      String?
  createdAt           DateTime          @default(now())

  @@unique([commissionRequestId, sellerProfileId])
  @@index([sellerProfileId])
}

model Metro {
  id          String   @id @default(cuid())
  slug        String   @unique @db.VarChar(100)
  name        String   @db.VarChar(100)
  state       String   @db.VarChar(50)
  latitude    Float
  longitude   Float
  radiusMiles Int      @default(45)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Self-relation: child metros roll up to a parent major metro
  parentMetroId String?
  parentMetro   Metro?  @relation("MetroChildren", fields: [parentMetroId], references: [id])
  childMetros   Metro[] @relation("MetroChildren")

  // Back-relations
  listings             Listing[]           @relation("ListingMetro")
  listingCityMetros    Listing[]           @relation("ListingCityMetro")
  commissions          CommissionRequest[] @relation("CommissionMetro")
  commissionCityMetros CommissionRequest[] @relation("CommissionCityMetro")
  sellerProfiles       SellerProfile[]     @relation("SellerMetro")
  sellerCityProfiles   SellerProfile[]     @relation("SellerCityMetro")

  @@index([slug])
  @@index([parentMetroId])
  @@index([state, isActive])
}

model AdminAuditLog {
  id           String    @id @default(cuid())
  adminId      String
  admin        User      @relation("AdminActions", fields: [adminId], references: [id])
  action       String    @db.VarChar(100)
  targetType   String    @db.VarChar(100)
  targetId     String    @db.VarChar(255)
  reason       String?   @db.VarChar(1000)
  metadata     Json      @default("{}")
  undone       Boolean   @default(false)
  undoneAt     DateTime?
  undoneBy     String?   @db.VarChar(255)
  undoneReason String?   @db.VarChar(1000)
  createdAt    DateTime  @default(now())

  @@index([adminId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@index([undone])
}

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("UserBlocks", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("UserBlockedBy", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

model UserReport {
  id           String    @id @default(cuid())
  reporterId   String
  reportedId   String
  reason       String    @db.VarChar(100)
  details      String?   @db.VarChar(2000)
  targetType   String?   @db.VarChar(100)
  targetId     String?   @db.VarChar(255)
  resolved     Boolean   @default(false)
  resolvedAt   DateTime?
  resolvedById String?
  createdAt    DateTime  @default(now())

  reporter   User  @relation("UserReports", fields: [reporterId], references: [id], onDelete: Cascade)
  reported   User  @relation("UserReportedBy", fields: [reportedId], references: [id], onDelete: Cascade)
  resolvedBy User? @relation("UserReportsResolved", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([reporterId])
  @@index([reportedId])
  @@index([resolved])
  @@index([resolvedById])
}
