enum BlogPostType {
  STANDARD
  MAKER_SPOTLIGHT
  BEHIND_THE_BUILD
  GIFT_GUIDE
  WOOD_EDUCATION
}

enum BlogPostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum BlogAuthorType {
  STAFF
  MAKER
}

model BlogPost {
  id                 String          @id @default(cuid())
  slug               String          @unique @db.VarChar(255)
  title              String          @db.VarChar(200)
  excerpt            String?         @db.VarChar(500)
  body               String
  coverImageUrl      String?         @db.VarChar(2048)
  videoUrl           String?         @db.VarChar(2048)
  authorId           String
  author             User            @relation("BlogPostsAuthored", fields: [authorId], references: [id])
  authorType         BlogAuthorType
  sellerProfileId    String?
  sellerProfile      SellerProfile?  @relation(fields: [sellerProfileId], references: [id])
  type               BlogPostType    @default(STANDARD)
  status             BlogPostStatus  @default(DRAFT)
  featuredListingIds String[]        @default([])
  tags               String[]        @default([])
  metaDescription    String?         @db.VarChar(320)
  readingTimeMinutes Int?
  publishedAt        DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  comments           BlogComment[]
  savedBy            SavedBlogPost[]

  @@index([status, publishedAt])
  @@index([authorId])
  @@index([sellerProfileId])
  @@index([title])
  @@index([tags])
}

model BlogComment {
  id        String        @id @default(cuid())
  postId    String
  post      BlogPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User          @relation("BlogCommentsAuthored", fields: [authorId], references: [id], onDelete: Cascade)
  body      String        @db.VarChar(2000)
  approved  Boolean       @default(false)
  parentId  String?
  parent    BlogComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   BlogComment[] @relation("CommentReplies")
  createdAt DateTime      @default(now())

  @@index([postId])
  @@index([postId, createdAt])
  @@index([parentId])
}

model NewsletterSubscriber {
  id           String   @id @default(cuid())
  email        String   @unique @db.VarChar(254)
  name         String?  @db.VarChar(200)
  subscribedAt DateTime @default(now())
  active       Boolean  @default(true)
}

enum EmailSuppressionReason {
